# ---------- App ----------
APP_NAME=M Kharavad Company
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mkharavad
# One-time setup only (postgres superuser password for scripts/setup_db.py)
# POSTGRES_ADMIN_PASSWORD=

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- OTP (Renflair SMS) ----------
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=4
OTP_DEBUG=false

# ---------- Renflair SMS ----------
# OTP: https://sms.renflair.in/V1.php?API=&PHONE=&OTP=
# Order success: https://sms.renflair.in/V3.php?API=&PHONE=&OID=&CNAME=
RENFLAIR_API_KEY=

# ---------- Twilio (legacy — unused) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------- Admin seed ----------
ADMIN_EMAIL=admin@mkharavad.com
ADMIN_PASSWORD=Admin@12345

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- BunnyCDN Storage ----------
BUNNY_STORAGE_ZONE=mkharavad-media
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_REGION=sg
BUNNY_CDN_URL=https://mkharavad-media.b-cdn.net

# API user: Shiprocket dashboard → Settings → API → Create API User (email + password)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external
# Must match pickup location nickname (Settings → Pickup Addresses), often "Primary"
# Must match pickup nickname in Shiprocket exactly (Settings → Pickup Address)
SHIPROCKET_PICKUP_LOCATION=work
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_COURIER_ID=
# Push every new order to Shiprocket automatically
SHIPROCKET_AUTO_PUSH=true
# Set true only after courier is activated / wallet funded
SHIPROCKET_AUTO_AWB=false
SHIPROCKET_DEFAULT_LENGTH=10
SHIPROCKET_DEFAULT_BREADTH=10
SHIPROCKET_DEFAULT_HEIGHT=10
